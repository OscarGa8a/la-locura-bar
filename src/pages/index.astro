---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

import TopBar from '../components/sections/TopBar.astro';
import Marquee from '../components/sections/Marquee.astro';
import Hero from '../components/sections/Hero.astro';
import Events from '../components/sections/Events.astro';
import About from '../components/sections/About.astro';
import MenuSection from '../components/sections/MenuSection.astro';
import Gallery from '../components/sections/Gallery.astro';
import Reserve from '../components/sections/Reserve.astro';
import Location from '../components/sections/Location.astro';
import Footer from '../components/sections/Footer.astro';
import MenuOverlay from '../components/sections/MenuOverlay.astro';
---

<Layout
  title="Cervezas frías, tragos y locura bien hecha en Villavicencio"
  description="Bar en Villavicencio. Cervezas frías, tragos clásicos, noches temáticas de martes a domingo. Reserva tu mesa."
>
  <TopBar />
  <Marquee />
  <Hero />
  <Events />
  <About />
  <MenuSection />
  <Gallery />
  <Reserve />
  <Location />
  <Footer />
  <MenuOverlay />
</Layout>
