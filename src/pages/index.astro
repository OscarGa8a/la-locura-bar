---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

import TopBar from '../components/sections/TopBar.astro';
import Marquee from '../components/sections/Marquee.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import MenuSection from '../components/sections/MenuSection.astro';
import BillCalculator from '../components/sections/BillCalculator.astro';
import FAQ from '../components/sections/FAQ.astro';
import Reserve from '../components/sections/Reserve.astro';
import Location from '../components/sections/Location.astro';
import Footer from '../components/sections/Footer.astro';
import MenuOverlay from '../components/sections/MenuOverlay.astro';
import Activities from '../components/sections/Activities.astro';
import WhatsAppFab from '../components/ui/WhatsAppFab.astro';
import { FAQS } from '../data/content';

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQS.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout
  title="Bar con bolirana, baile y fútbol en Villavicencio"
  description="Bar en Villavicencio con bolirana, baile, cervezas frías, tragos clásicos, música, fútbol en pantalla gigante y reservas por WhatsApp."
  jsonLd={faqJsonLd}
>
  <TopBar />
  <main id="main-content" tabindex="-1">
    <Marquee />
    <Hero />
    <Activities />
    <About />
    <MenuSection />
    <BillCalculator />
    <Reserve />
    <Location />
    <FAQ />
  </main>
  <Footer />
  <MenuOverlay />
  <WhatsAppFab />
</Layout>
