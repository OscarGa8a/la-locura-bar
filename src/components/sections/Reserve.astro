---
import SectionHeader from "../ui/SectionHeader.astro";
import Icon from "../ui/Icons.astro";
import { COPY_NEON } from "../../data/content";
import Button from "../ui/Button.astro";
import { config } from "../../data/config";

const peopleOptions = [1, 2, 3, 4, 5, 6, 7, 8, 10];
const timeOptions = ["6 PM", "7 PM", "8 PM", "9 PM", "10 PM", "11 PM", "12 AM"];
const today = new Date().toISOString().split("T")[0];
const whatsappLink = `https://wa.me/${config.whatsapp}?text=Hola,%20quiero%20hacer%20una%20reserva`;
---

<section
  id="reserve"
  class="py-14 px-5 border-t border-line md:py-20 md:px-8 lg:py-24 lg:px-12"
  style="background: linear-gradient(180deg, transparent 0%, rgba(255,45,135,0.08) 100%)"
>
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Reservas"
      title="RESERVA TU MESA"
      sub={COPY_NEON.reserveNote}
    />
  
    <!-- Form view -->
    <form id="reserve-form" class="flex flex-wrap lg:-mx-2 gap-y-3.5 mt-7 mb-4 md:gap-y-4" data-reserve-form data-whatsapp={config.whatsapp}>
      <!-- Nombre -->
      <label class="flex flex-col w-full lg:w-1/2 gap-1.5 px-2 order-1 lg:order-1">
        <span class="font-mono text-xxs tracking-wide uppercase text-muted">Nombre</span>
        <input
          type="text"
          name="name"
          required
          placeholder="Tu nombre"
          class="py-3 px-3.5 bg-bg-3 border border-line-strong rounded-xl text-fg font-body text-base w-full outline-none md:py-3.5 md:px-4"
        />
      </label>
  
      <!-- Personas + Hora (grid) -->
      <!-- <div class="grid grid-cols-2 gap-2.5 md:gap-3 lg:gap-4">
      </div> -->
      <label class="flex flex-col gap-1.5 w-1/2 lg:px-2 order-2 lg:order-3">
        <span class="font-mono text-xxs tracking-wide uppercase text-muted">Personas</span>
        <select
          name="people"
          class="py-3 px-3.5 bg-bg-3 border border-line-strong rounded-xl text-fg font-body text-base w-full outline-none md:py-3.5 md:px-4"
        >
          {peopleOptions.map((n) => (
            <option value={n}>{n}</option>
          ))}
          <option value="10+">10+</option>
        </select>
      </label>
      <label class="flex flex-col gap-1.5 w-1/2 px-2 order-3 lg:order-4">
        <span class="font-mono text-xxs tracking-wide uppercase text-muted">Hora</span>
        <select
          name="time"
          class="py-3 px-3.5 bg-bg-3 border border-line-strong rounded-xl text-fg font-body text-base w-full outline-none md:py-3.5 md:px-4"
        >
          {timeOptions.map((t) => (
            <option value={t}>{t}</option>
          ))}
        </select>
      </label>
  
      <!-- Fecha -->
      <label class="flex flex-col gap-1.5 w-full lg:w-1/2 px-2 order-4 lg:order-2">
        <span class="font-mono text-xxs tracking-wide uppercase text-muted">Fecha</span>
        <input
          type="date"
          name="date"
          required
          min={today}
          class="py-3 px-3.5 bg-bg-3 border border-line-strong rounded-xl text-fg font-body text-base w-full outline-none md:py-3.5 md:px-4"
        />
      </label>
  
      <!-- Submit -->
      <Button type="submit" class="rounded-full mt-4 flex justify-center items-center gap-2 md:mt-5 order-5 lg:order-5 mx-auto w-full md:px-18 md:w-auto">
        Confirmar reserva <Icon name="arrow" />
      </Button>
    </form>
  
    <!-- Success view (hidden by default) -->
    <div id="reserve-success" class="hidden text-center py-14 md:py-20 lg:py-24" data-reserve-success>
      <div class="font-display text-5xl text-accent leading-none uppercase md:text-6xl lg:text-7xl">
        ¡Listo!
      </div>
      <p class="font-body text-base text-fg-dim mt-4 text-wrap-pretty md:text-lg" data-success-text>
        <!-- Populated by script -->
      </p>
      <button
        class="mt-5 py-2.5 px-5 border border-line-strong rounded-full font-body text-sm"
        data-reserve-reset
      >
        Hacer otra reserva
      </button>
    </div>
  
    <!-- WhatsApp link -->
    <a
      href={whatsappLink}
      target="_blank"
      rel="noopener noreferrer"
      class="flex justify-center items-center gap-2 py-3.5 font-body text-sm text-fg-dim md:text-base"
    >
      <Icon name="whatsapp" /> O escríbenos por WhatsApp
    </a>
  </div>
</section>

<script>
  // Reservation form — vanilla JS island
  const form = document.querySelector("[data-reserve-form]") as HTMLFormElement | null;
  const successView = document.querySelector("[data-reserve-success]") as HTMLElement | null;
  const successText = document.querySelector("[data-success-text]") as HTMLElement | null;
  const resetBtn = document.querySelector("[data-reserve-reset]") as HTMLButtonElement | null;

  if (form && successView && successText && resetBtn) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = data.get("name") as string;
      const people = data.get("people") as string;
      const time = data.get("time") as string;
      const date = (data.get("date") as string) || "—";
  
      successText.innerHTML = `Tu reserva para <b>${people}</b> personas el <b>${date}</b> a las <b>${time}</b> está en cola. Te confirmamos por WhatsApp en minutos, ${name}.`;
  
      const whatsapp = form.dataset.whatsapp;
      window.open(
        `https://wa.me/${whatsapp}?text=${encodeURIComponent(
          `¡Hola! Quisiera confirmar mi reserva para ${people} personas el ${date} a las ${time}. Mi nombre es ${name}.`
        )}`,
        "_blank",
        "noopener noreferrer"
      );
  
      form.classList.add("hidden");
      successView.classList.remove("hidden");
    });
  
    resetBtn.addEventListener("click", () => {
      successView.classList.add("hidden");
      form.classList.remove("hidden");
      form.reset();
    });
  }
</script>
