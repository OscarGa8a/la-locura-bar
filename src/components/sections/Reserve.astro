---
import SectionHeader from "../ui/SectionHeader.astro";
import Icon from "../ui/Icons.astro";
import { COPY_NEON } from "../../data/content";

const peopleOptions = [1, 2, 3, 4, 5, 6, 7, 8, 10];
const timeOptions = ["18:00", "19:00", "20:00", "21:00", "22:00", "23:00"];
---

<section
  id="reserve"
  class="pt-14 px-5 border-t border-line"
  style="background: linear-gradient(180deg, transparent 0%, rgba(255,45,135,0.08) 100%)"
>
  <SectionHeader
    eyebrow="Reservas"
    title="RESERVA TU MESA"
    sub={COPY_NEON.reserveNote}
  />

  <!-- Form view -->
  <form id="reserve-form" class="flex flex-col gap-3.5 mt-7" data-reserve-form>
    <!-- Nombre -->
    <label class="flex flex-col gap-1.5">
      <span class="font-mono text-[10px] tracking-wide uppercase text-muted">Nombre</span>
      <input
        type="text"
        name="name"
        required
        placeholder="Tu nombre"
        class="py-3 px-3.5 bg-bg-3 border border-line-strong rounded-[10px] text-fg font-body text-[15px] w-full outline-none"
      />
    </label>

    <!-- Personas + Hora (grid) -->
    <div class="grid grid-cols-2 gap-2.5">
      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-[10px] tracking-wide uppercase text-muted">Personas</span>
        <select
          name="people"
          class="py-3 px-3.5 bg-bg-3 border border-line-strong rounded-[10px] text-fg font-body text-[15px] w-full outline-none"
        >
          {peopleOptions.map((n) => (
            <option value={n}>{n}</option>
          ))}
          <option value="10+">10+</option>
        </select>
      </label>
      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-[10px] tracking-wide uppercase text-muted">Hora</span>
        <select
          name="time"
          class="py-3 px-3.5 bg-bg-3 border border-line-strong rounded-[10px] text-fg font-body text-[15px] w-full outline-none"
        >
          {timeOptions.map((t) => (
            <option value={t}>{t}</option>
          ))}
        </select>
      </label>
    </div>

    <!-- Fecha -->
    <label class="flex flex-col gap-1.5">
      <span class="font-mono text-[10px] tracking-wide uppercase text-muted">Fecha</span>
      <input
        type="date"
        name="date"
        required
        class="py-3 px-3.5 bg-bg-3 border border-line-strong rounded-[10px] text-fg font-body text-[15px] w-full outline-none"
      />
    </label>

    <!-- WhatsApp -->
    <label class="flex flex-col gap-1.5">
      <span class="font-mono text-[10px] tracking-wide uppercase text-muted">WhatsApp</span>
      <input
        type="tel"
        name="phone"
        required
        placeholder="+57 300 000 0000"
        class="py-3 px-3.5 bg-bg-3 border border-line-strong rounded-[10px] text-fg font-body text-[15px] w-full outline-none"
      />
    </label>

    <!-- Submit -->
    <button
      type="submit"
      class="py-4 px-5 bg-accent text-bg font-display text-base tracking-wide uppercase rounded-full mt-2 flex justify-center items-center gap-2"
    >
      Confirmar reserva <Icon name="arrow" />
    </button>
  </form>

  <!-- Success view (hidden by default) -->
  <div id="reserve-success" class="hidden text-center py-14" data-reserve-success>
    <div class="font-display text-[44px] text-accent leading-none uppercase">
      ¡Listo!
    </div>
    <p class="font-body text-[15px] text-fg-dim mt-4 text-wrap-pretty" data-success-text>
      <!-- Populated by script -->
    </p>
    <button
      class="mt-5 py-2.5 px-5 border border-line-strong rounded-full font-body text-[13px]"
      data-reserve-reset
    >
      Hacer otra reserva
    </button>
  </div>

  <!-- WhatsApp link -->
  <a
    href="#"
    class="mt-3.5 flex justify-center items-center gap-2 py-3.5 font-body text-[13px] text-fg-dim"
  >
    <Icon name="whatsapp" /> O escríbenos por WhatsApp
  </a>
</section>

<script>
  // Reservation form — vanilla JS island
  const form = document.querySelector("[data-reserve-form]") as HTMLFormElement | null;
  const successView = document.querySelector("[data-reserve-success]") as HTMLElement | null;
  const successText = document.querySelector("[data-success-text]") as HTMLElement | null;
  const resetBtn = document.querySelector("[data-reserve-reset]") as HTMLButtonElement | null;

  if (form && successView && successText && resetBtn) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = data.get("name") as string;
      const people = data.get("people") as string;
      const time = data.get("time") as string;
      const date = (data.get("date") as string) || "—";

      successText.innerHTML = `Tu reserva para <b>${people}</b> personas el <b>${date}</b> a las <b>${time}</b> está en cola. Te confirmamos por WhatsApp en minutos, ${name}.`;

      form.classList.add("hidden");
      successView.classList.remove("hidden");
    });

    resetBtn.addEventListener("click", () => {
      successView.classList.add("hidden");
      form.classList.remove("hidden");
      form.reset();
    });
  }
</script>
