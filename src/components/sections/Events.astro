---
import SectionHeader from "../ui/SectionHeader.astro";
import { WEEK_EVENTS, COPY_NEON } from "../../data/content";
---

<section
  id="events"
  class="py-14 px-5 pb-12 border-t border-b border-line"
>
  <SectionHeader
    eyebrow={COPY_NEON.promoBadge}
    title="LA SEMANA"
    sub="Cada noche tiene su propia locura."
  />

  <div class="flex flex-col gap-2 mt-8">
    {WEEK_EVENTS.map((event, i) => (
      <div data-day-index={i} data-event-row>
        {event.closed ? (
          /* Closed day row */
          <div class="py-4.5 px-3.5 bg-bg-2 flex items-center gap-4 opacity-50">
            <div class="font-mono text-[11px] tracking-wide w-10 text-muted">
              {event.day}
            </div>
            <div class="font-display text-lg text-muted line-through">
              {event.name} — {event.sub}
            </div>
          </div>
        ) : (
          /* Normal day row */
          <div class="py-4 px-3.5 bg-bg-2 flex items-start gap-4 relative" data-event-inner>
            <div class="font-display text-[22px] font-normal tracking-[0.05em] w-14 shrink-0" data-day-label>
              {event.day}
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-display text-[22px] leading-[1.1] tracking-[0.02em] uppercase text-fg mb-1">
                {event.name}
              </div>
              <div class="font-body text-[13px] text-fg-dim leading-snug">
                {event.sub}
              </div>
              {event.tag && (
                <div class="inline-block mt-2 py-1 px-2.5 bg-accent text-bg font-mono text-[10px] tracking-wide uppercase font-semibold rounded-sm">
                  {event.tag}
                </div>
              )}
            </div>
            {/* HOY badge — hidden by default, shown by script */}
            <div class="hidden font-mono text-[9px] tracking-wide text-accent py-0.5 px-1.5 border border-accent rounded-full self-start" data-hoy-badge>
              HOY
            </div>
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<script>
  // Client-side today detection — avoids SSR date mismatch
  const dayMap = [6, 0, 1, 2, 3, 4, 5]; // getDay() → LUN-DOM index
  const today = new Date().getDay();
  const todayIndex = dayMap[today];

  const rows = document.querySelectorAll("[data-event-row]");
  rows.forEach((row) => {
    const idx = Number(row.getAttribute("data-day-index"));
    if (idx === todayIndex) {
      row.setAttribute("data-today", "");

      // Apply today styling to inner div
      const inner = row.querySelector("[data-event-inner]");
      if (inner) {
        inner.style.background =
          "linear-gradient(90deg, rgba(255,45,135,0.15), rgba(0,229,255,0.1))";
        inner.style.border = "1px solid var(--color-accent)";
      }

      // Accent the day label
      const dayLabel = row.querySelector("[data-day-label]");
      if (dayLabel) {
        dayLabel.style.color = "var(--color-accent)";
      }

      // Show HOY badge
      const hoy = row.querySelector("[data-hoy-badge]");
      if (hoy) {
        hoy.classList.remove("hidden");
      }
    }
  });
</script>
