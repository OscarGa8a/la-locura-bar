---
import Icon from "../ui/Icons.astro";
import { COPY_NEON, WEEK_EVENTS } from "../../data/content";
import Button from "../ui/Button.astro";

const today = new Date().getDay(); // 0 (Sun) to 6 (Sat)
const adjustedDay = today === 0 ? 6 : today - 1; // Adjust so Monday=0, Sunday=6
// Pick tonight's event (skip closed days — first open event)
const tonightEvent = WEEK_EVENTS[adjustedDay];
---

<section
  class="relative py-8 px-5 pb-15 overflow-hidden"
  style="background: radial-gradient(ellipse at 20% 0%, rgba(255,45,135,0.3) 0%, transparent 60%), radial-gradient(ellipse at 80% 100%, rgba(0,229,255,0.25) 0%, transparent 60%)"
>
  <!-- Grid overlay -->
  <div class="absolute inset-0 opacity-15 bg-grid" />

  <div class="relative">
    <!-- LIVE ticker -->
    <div class="inline-flex gap-1.5 items-center py-1 px-2.5 border border-accent text-accent font-mono text-xxs tracking-ultra uppercase mb-10">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse" />
      EN VIVO · ABIERTO HOY
    </div>

    <!-- Title -->
    <h1 class="font-display text-7xl tracking-neon font-normal uppercase m-0 text-fg text-glow">
      <span class="block">LA</span>
      <span class="block text-accent-2 text-glow-cyan">LOCURA</span>
      <span class="block text-xl text-fg-dim tracking-ultra mt-2 text-shadow-none">
        // BAR
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="font-body text-base leading-relaxed text-fg-dim mt-10 mb-6 max-w-85 text-wrap-pretty">
      {COPY_NEON.heroSub}
    </p>

    <!-- CTAs -->
     <div class="flex gap-2.5 flex-wrap">
      <Button href="#reserve" variant="primary">
        {COPY_NEON.ctaPrimary} <Icon name="arrow" />
      </Button>

      <Button href="#menu" variant="outline-secondary">
        {COPY_NEON.ctaSecondary}
      </Button>
    </div>

    <!-- Tonight chip -->
    <div class="mt-15 py-3 px-3.5 border border-dashed border-line-strong flex items-center gap-3 font-mono text-xs tracking-wider">
      <span class="text-accent">◉</span>
      {tonightEvent.closed
        ? "CERRADO HOY · NOS VEMOS MAÑANA"
        : `HOY: ${tonightEvent.name.toUpperCase()} · DESDE 6PM`
      }
    </div>
  </div>
</section>
