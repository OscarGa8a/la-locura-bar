---
import Icon from "../ui/Icons.astro";
import { COPY_NEON } from "../../data/content";
import Button from "../ui/Button.astro";
---

<!-- ═══════════════════════════════════════════ -->
<!-- MOBILE HERO (unchanged, hidden on md+)    -->
<!-- ═══════════════════════════════════════════ -->
<section
  class="relative py-8 px-5 pb-15 overflow-hidden md:hidden"
  style="background: radial-gradient(ellipse at 20% 0%, rgba(255,45,135,0.3) 0%, transparent 60%), radial-gradient(ellipse at 80% 100%, rgba(0,229,255,0.25) 0%, transparent 60%)"
>
  <!-- Grid overlay -->
  <div class="absolute inset-0 opacity-15 bg-grid" />

  <div class="relative" data-animate-container>
    <!-- LIVE ticker -->
    <div class="inline-flex gap-1.5 items-center py-1 px-2.5 border border-accent text-accent font-mono text-xxs tracking-ultra uppercase mb-10" data-animate="fade-up" data-animate-delay="1">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse" />
      EN VIVO · ABIERTO HOY
    </div>

    <!-- Title -->
    <h1 class="font-display text-7xl tracking-neon font-normal uppercase m-0 text-fg text-glow" data-animate="fade-up" data-animate-delay="2">
      <span class="block">LA</span>
      <span class="block text-accent-2 text-glow-cyan">LOCURA</span>
      <span class="block text-xl text-fg-dim tracking-ultra mt-2 text-shadow-none">
        // BAR EN VILLAVICENCIO
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="font-body text-base leading-relaxed text-fg-dim mt-10 mb-6 max-w-85 text-wrap-pretty" data-animate="fade-up" data-animate-delay="3">
      {COPY_NEON.heroSub}
    </p>

    <!-- CTAs -->
    <div class="flex gap-2.5 flex-wrap" data-animate="fade-up" data-animate-delay="4">
      <Button href="#reserve" variant="primary">
        {COPY_NEON.ctaPrimary} <Icon name="arrow" />
      </Button>

      <Button href="#menu" variant="outline-secondary">
        {COPY_NEON.ctaSecondary}
      </Button>
    </div>

    <!-- Tonight chip -->
    <div class="mt-15 py-3 px-3.5 border border-dashed border-line-strong flex items-center gap-3 font-mono text-xs tracking-wider" data-animate="fade-up" data-animate-delay="5">
      <span class="text-accent">◉</span> BOLIRANA, FÚTBOL Y PARCHE
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════ -->
<!-- DESKTOP HERO (hidden on mobile, flex md+)  -->
<!-- ═══════════════════════════════════════════ -->
<section
  class="hidden md:flex md:flex-col md:justify-center md:min-h-[calc(100dvh-105px)] md:relative md:px-8 lg:px-12 md:overflow-hidden md:py-0"
  style="background: radial-gradient(ellipse at 20% 0%, rgba(255,45,135,0.3) 0%, transparent 60%), radial-gradient(ellipse at 80% 100%, rgba(0,229,255,0.25) 0%, transparent 60%)"
>
  <!-- Grid overlay -->
  <div class="absolute inset-0 opacity-15 bg-grid" />

  <!-- Logo watermark -->
  <img
    src="/images/logo-transparent.png"
    alt=""
    aria-hidden="true"
    class="absolute right-2 top-2 w-80 opacity-30 pointer-events-none select-none lg:w-100"
  />

  <!-- Inner container centered, max-width constrained -->
  <div class="relative w-full max-w-7xl mx-auto md:py-16 lg:py-20" data-animate-container>

    <div class="flex flex-col">
      <!-- Top row: LIVE ticker -->
      <div class="inline-flex gap-1.5 items-center py-1 px-3 w-fit border border-accent text-accent font-mono text-xs tracking-ultra uppercase mb-8" data-animate="fade-up" data-animate-delay="1">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse" />
        EN VIVO · ABIERTO HOY
      </div>

      <!-- Brand name — single line, scales with viewport -->
      <h1 class="font-display font-normal uppercase m-0 leading-none text-fg text-glow inline-flex items-baseline flex-nowrap gap-x-2 md:gap-x-3 lg:gap-x-4" data-animate="fade-up" data-animate-delay="2">
        <span class="text-5xl md:text-8xl lg:text-9xl">LA</span>
        <span class="text-7xl md:text-8xl lg:text-9xl text-accent-2 text-glow-cyan">LOCURA</span>
        <span class="text-sm md:text-base lg:text-lg text-fg-dim tracking-ultra self-end pb-1">// BAR EN VILLAVICENCIO</span>
      </h1>
    </div>

    <!-- Main content area: subtitle + CTAs left, event card right on lg -->
    <div class="flex flex-col lg:flex-row lg:items-start lg:gap-16 mt-8 lg:mt-10" data-animate="fade-up" data-animate-delay="3">

      <!-- Left column: subtitle + CTAs -->
      <div class="flex-1 min-w-0">
        <p class="font-body text-lg leading-relaxed text-fg-dim mb-8 max-w-xl text-wrap-pretty lg:text-xl lg:mb-10">
          {COPY_NEON.heroSub}
        </p>

        <!-- CTAs -->
        <div class="flex gap-4 flex-wrap">
          <Button href="#reserve" variant="primary">
            {COPY_NEON.ctaPrimary} <Icon name="arrow" />
          </Button>

          <Button href="#menu" variant="outline-secondary">
            {COPY_NEON.ctaSecondary}
          </Button>
        </div>
      </div>

      <!-- Right column: static featured card -->
      <div class="mt-8 lg:mt-0 lg:w-80 lg:shrink-0 max-w-xl" data-animate="fade-up" data-animate-delay="5">
        <div class="py-5 px-5 border border-dashed border-line-strong rounded-xl bg-bg-2 backdrop-blur-sm">
          <div class="font-mono text-xxs tracking-ultra uppercase text-muted mb-3">
            BOLIRANA, FÚTBOL Y PARCHE
          </div>
          <div class="font-display text-3xl leading-none tracking-wider uppercase text-fg mb-2">
            Vení al parche
          </div>
          <div class="font-body text-sm text-fg-dim mb-3">
            Cerveza fría, bolirana con amigos, música y ambiente de barrio sin complicarse.
          </div>
          <div class="inline-block py-1 px-2.5 bg-accent text-bg font-mono text-xs tracking-wide uppercase font-semibold rounded-sm">
            ARMA LA PARTIDA
          </div>
          <div class="mt-4 font-mono text-xs text-accent tracking-wide">
            MARTES A DOMINGO DESDE LAS 6 PM
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
