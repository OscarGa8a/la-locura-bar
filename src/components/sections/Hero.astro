---
import Icon from "../ui/Icons.astro";
import { COPY_NEON, WEEK_EVENTS } from "../../data/content";
import Button from "../ui/Button.astro";

const today = new Date().getDay(); // 0 (Sun) to 6 (Sat)
const adjustedDay = today === 0 ? 6 : today - 1; // Adjust so Monday=0, Sunday=6
const tonightEvent = WEEK_EVENTS[adjustedDay];
---

<!-- ═══════════════════════════════════════════ -->
<!-- MOBILE HERO (unchanged, hidden on md+)    -->
<!-- ═══════════════════════════════════════════ -->
<section
  class="relative py-8 px-5 pb-15 overflow-hidden md:hidden"
  style="background: radial-gradient(ellipse at 20% 0%, rgba(255,45,135,0.3) 0%, transparent 60%), radial-gradient(ellipse at 80% 100%, rgba(0,229,255,0.25) 0%, transparent 60%)"
>
  <!-- Grid overlay -->
  <div class="absolute inset-0 opacity-15 bg-grid" />

  <div class="relative">
    <!-- LIVE ticker -->
    <div class="inline-flex gap-1.5 items-center py-1 px-2.5 border border-accent text-accent font-mono text-xxs tracking-ultra uppercase mb-10">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse" />
      EN VIVO · ABIERTO HOY
    </div>

    <!-- Title -->
    <h1 class="font-display text-7xl tracking-neon font-normal uppercase m-0 text-fg text-glow">
      <span class="block">LA</span>
      <span class="block text-accent-2 text-glow-cyan">LOCURA</span>
      <span class="block text-xl text-fg-dim tracking-ultra mt-2 text-shadow-none">
        // BAR
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="font-body text-base leading-relaxed text-fg-dim mt-10 mb-6 max-w-85 text-wrap-pretty">
      {COPY_NEON.heroSub}
    </p>

    <!-- CTAs -->
    <div class="flex gap-2.5 flex-wrap">
      <Button href="#reserve" variant="primary">
        {COPY_NEON.ctaPrimary} <Icon name="arrow" />
      </Button>

      <Button href="#menu" variant="outline-secondary">
        {COPY_NEON.ctaSecondary}
      </Button>
    </div>

    <!-- Tonight chip -->
    <div class="mt-15 py-3 px-3.5 border border-dashed border-line-strong flex items-center gap-3 font-mono text-xs tracking-wider">
      <span class="text-accent">◉</span>
      {tonightEvent.closed
        ? "CERRADO HOY · NOS VEMOS MAÑANA"
        : `HOY: ${tonightEvent.name.toUpperCase()} · DESDE 6PM`
      }
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════ -->
<!-- DESKTOP HERO (hidden on mobile, flex md+)  -->
<!-- ═══════════════════════════════════════════ -->
<section
  class="hidden md:flex md:flex-col md:justify-center md:min-h-[calc(100dvh-105px)] md:relative md:px-8 lg:px-12 md:overflow-hidden md:py-0"
  style="background: radial-gradient(ellipse at 20% 0%, rgba(255,45,135,0.3) 0%, transparent 60%), radial-gradient(ellipse at 80% 100%, rgba(0,229,255,0.25) 0%, transparent 60%)"
>
  <!-- Grid overlay -->
  <div class="absolute inset-0 opacity-15 bg-grid" />

  <!-- Inner container centered, max-width constrained -->
  <div class="relative w-full max-w-7xl mx-auto md:py-16 lg:py-20">

    <div class="flex flex-col">
      <!-- Top row: LIVE ticker -->
      <div class="inline-flex gap-1.5 items-center py-1 px-3 w-fit border border-accent text-accent font-mono text-xs tracking-ultra uppercase mb-8">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse" />
        EN VIVO · ABIERTO HOY
      </div>
  
      <!-- Brand name — single line, scales with viewport -->
      <h1 class="font-display font-normal uppercase m-0 leading-none text-fg text-glow inline-flex items-baseline flex-nowrap gap-x-2 md:gap-x-3 lg:gap-x-4">
        <span class="text-5xl md:text-8xl lg:text-9xl">LA</span>
        <span class="text-7xl md:text-8xl lg:text-9xl text-accent-2 text-glow-cyan">LOCURA</span>
        <span class="text-sm md:text-base lg:text-lg text-fg-dim tracking-ultra self-end pb-1">// BAR</span>
      </h1>
    </div>

    <!-- Main content area: subtitle + CTAs left, event card right on lg -->
    <div class="flex flex-col lg:flex-row lg:items-start lg:gap-16 mt-8 lg:mt-10">

      <!-- Left column: subtitle + CTAs -->
      <div class="flex-1 min-w-0">
        <p class="font-body text-lg leading-relaxed text-fg-dim mb-8 max-w-xl text-wrap-pretty lg:text-xl lg:mb-10">
          {COPY_NEON.heroSub}
        </p>

        <!-- CTAs -->
        <div class="flex gap-4 flex-wrap">
          <Button href="#reserve" variant="primary">
            {COPY_NEON.ctaPrimary} <Icon name="arrow" />
          </Button>

          <Button href="#menu" variant="outline-secondary">
            {COPY_NEON.ctaSecondary}
          </Button>
        </div>
      </div>

      <!-- Right column: tonight event — visual card -->
      <div class="mt-8 lg:mt-0 lg:w-80 lg:shrink-0 max-w-xl">
        <div class="py-5 px-5 border border-dashed border-line-strong rounded-xl bg-bg-2 backdrop-blur-sm">
          <div class="font-mono text-xxs tracking-ultra uppercase text-muted mb-3">
            Esta noche
          </div>
          {tonightEvent.closed ? (
            <div class="font-display text-2xl text-muted leading-none uppercase line-through">
              Cerrado
            </div>
          ) : (
            <>
              <div class="font-display text-3xl leading-none tracking-wider uppercase text-fg mb-2">
                {tonightEvent.name}
              </div>
              <div class="font-body text-sm text-fg-dim mb-3">
                {tonightEvent.sub}
              </div>
              {tonightEvent.tag && (
                <div class="inline-block py-1 px-2.5 bg-accent text-bg font-mono text-xs tracking-wide uppercase font-semibold rounded-sm">
                  {tonightEvent.tag}
                </div>
              )}
              <div class="mt-4 font-mono text-xs text-accent tracking-wide">
                DESDE LAS 6 PM
              </div>
            </>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
