---
import SectionHeader from '../ui/SectionHeader.astro';
import { FAQS } from '../../data/content';
---

<section id="faq" class="py-14 px-5 border-t border-line md:py-20 md:px-8 lg:py-24 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:gap-12">
      <div>
        <SectionHeader
          eyebrow="Preguntas frecuentes"
          title="ANTES DE CAER"
          sub="Respuestas rápidas para reservar, llegar y saber qué plan se arma en La Locura."
        />
      </div>

      <div class="space-y-3">
        {FAQS.map((item) => (
          <details
            class="faq-item rounded-xl border border-line bg-bg-2/70 px-4 py-3 transition-colors open:border-accent/70 md:px-5 md:py-4"
            data-faq-item
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-body text-base font-semibold text-fg md:text-lg [&::-webkit-details-marker]:hidden">
              <span>{item.question}</span>
              <span class="faq-icon shrink-0 rounded-full border border-line-strong px-2 py-0.5 font-mono text-xs text-accent transition-transform" aria-hidden="true">
                +
              </span>
            </summary>
            <div class="faq-answer">
              <div class="faq-answer-inner">
                <p class="mt-3 border-t border-line pt-3 font-body text-sm leading-relaxed text-fg-dim md:text-base">
                  {item.answer}
                </p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 500ms ease,
      opacity 400ms ease;
  }

  .faq-answer-inner {
    overflow: hidden;
  }

  .faq-item[open]:not(.is-closing) .faq-answer {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .faq-item[open]:not(.is-closing) .faq-icon {
    transform: rotate(45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-answer,
    .faq-icon {
      transition: none;
    }
  }
</style>

<script>
  const faqItems = document.querySelectorAll<HTMLDetailsElement>('[data-faq-item]');
  const closeAnimationMs = 500;

  faqItems.forEach((item) => {
    const summary = item.querySelector('summary');
    let closeTimer: number | undefined;

    summary?.addEventListener('click', (event) => {
      if (!item.open) return;

      event.preventDefault();
      window.clearTimeout(closeTimer);
      item.classList.add('is-closing');

      closeTimer = window.setTimeout(() => {
        item.open = false;
        item.classList.remove('is-closing');
      }, closeAnimationMs);
    });
  });
</script>
