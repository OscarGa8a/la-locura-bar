---
import Icon from "../ui/Icons.astro";
import { NAV_LINKS } from "../../data/content";
---

<div
  id="menu-overlay"
  class="hidden fixed inset-0 z-50 bg-bg flex-col py-15 px-7 pb-10 overflow-auto"
>
  <!-- Close button -->
  <button
    data-menu-close
    class="absolute top-4.5 right-5 text-fg"
  >
    <Icon name="close" />
  </button>

  <!-- Nav links -->
  <div class="flex flex-col gap-1 my-5">
    {NAV_LINKS.map((link) => (
      <a
        href={link.href}
        class="py-4 border-b border-line font-display text-[30px] font-normal tracking-[0.04em] uppercase flex justify-between items-center"
      >
        <span>{link.label.toUpperCase()}</span>
        <Icon name="arrow" class="text-accent" />
      </a>
    ))}
  </div>
</div>
