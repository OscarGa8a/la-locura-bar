---
import Icon from "../ui/Icons.astro";
import { socialNetworks } from "../../data/social-networks";

const currentYear = new Date().getFullYear();
---

<footer class="pt-12 px-5 pb-8 border-t border-line-strong md:pt-16 md:px-8 md:pb-10 lg:pt-20 lg:px-12">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between md:items-center gap-4">
    <div class="flex flex-col justify-center">
      <!-- Brand name -->
      <div class="font-display text-5xl font-normal tracking-wider uppercase text-accent md:text-6xl lg:text-7xl">
        LA LOCURA.
      </div>
    
      <!-- Tagline -->
      <div class="font-body text-sm mt-3 opacity-80 text-wrap-pretty md:text-base md:mt-4">
        Síguenos y no te pierdas la próxima locura.
      </div>
    </div>
    
    <!-- Social link cards -->
    <div class="flex gap-2 mt-5 lg:mt-0 md:gap-3 md:max-w-md lg:max-w-lg">
      {socialNetworks.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 py-3 px-1 border border-line-strong rounded-lg flex flex-col items-center gap-1.5 font-mono text-xxs md:py-4 md:px-2 hover:bg-bg-2 transition-colors md:text-xs"
        >
          <Icon name={s.icon} />
          <span class="text-center">{s.label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Copyright strip -->
  <div class="mt-9 pt-5 border-t border-line font-mono text-xxs tracking-neon opacity-60 flex justify-between flex-wrap gap-2 md:mt-12 md:pt-6">
    <span>© {currentYear} LA LOCURA BAR</span>
    <span>VILLAVICENCIO · CO</span>
  </div>
</footer>
