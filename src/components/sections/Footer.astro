---
import Icon from "../ui/Icons.astro";

const socials = [
  { icon: "instagram" as const, label: "@lalocura.bar" },
  { icon: "tiktok" as const, label: "@lalocurabar" },
  { icon: "facebook" as const, label: "La Locura Bar" },
];
---

<footer class="pt-12 px-5 pb-8 border-t border-line-strong">
  <!-- Brand name -->
  <div class="font-display text-[48px] leading-[0.9] font-normal tracking-[0.02em] uppercase text-accent">
    LA LOCURA.
  </div>

  <!-- Tagline -->
  <div class="font-body text-sm mt-3 opacity-80 text-wrap-pretty">
    Síguenos y no te pierdas la próxima locura.
  </div>

  <!-- Social link cards -->
  <div class="flex gap-2.5 mt-5">
    {socials.map((s) => (
      <a
        href="#"
        class="flex-1 py-3 px-2.5 border border-line-strong rounded-[10px] flex flex-col items-center gap-1.5 font-mono text-[10px] tracking-[0.06em]"
      >
        <Icon name={s.icon} />
        <span>{s.label}</span>
      </a>
    ))}
  </div>

  <!-- Copyright strip -->
  <div class="mt-9 pt-5 border-t border-line font-mono text-[10px] tracking-neon opacity-60 flex justify-between flex-wrap gap-2">
    <span>© 2026 LA LOCURA BAR</span>
    <span>MEDELLÍN · CO</span>
  </div>
</footer>
