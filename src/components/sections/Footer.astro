---
import Icon from "../ui/Icons.astro";
import { socialNetworks } from "../../data/social-networks";

const currentYear = new Date().getFullYear();
---

<footer class="pt-12 px-5 pb-8 border-t border-line-strong">
  <!-- Brand name -->
  <div class="font-display text-5xl font-normal tracking-wider uppercase text-accent">
    LA LOCURA.
  </div>

  <!-- Tagline -->
  <div class="font-body text-sm mt-3 opacity-80 text-wrap-pretty">
    Síguenos y no te pierdas la próxima locura.
  </div>

  <!-- Social link cards -->
  <div class="flex gap-2 mt-5">
    {socialNetworks.map((s) => (
      <a
        href={s.href}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 py-3 px-1 border border-line-strong rounded-lg flex flex-col items-center gap-1.5 font-mono text-xxs"
      >
        <Icon name={s.icon} />
        <span class="text-center">{s.label}</span>
      </a>
    ))}
  </div>

  <!-- Copyright strip -->
  <div class="mt-9 pt-5 border-t border-line font-mono text-xxs tracking-neon opacity-60 flex justify-between flex-wrap gap-2">
    <span>© {currentYear} LA LOCURA BAR</span>
    <span>VILLAVICENCIO · CO</span>
  </div>
</footer>
