---
import SectionHeader from "../ui/SectionHeader.astro";
import PlaceholderImg from "../ui/PlaceholderImg.astro";
import Icon from "../ui/Icons.astro";

const shots = [
  { label: "ambiente · viernes salsa", w: 400, h: 500, tall: true },
  { label: "cerveza jarra", w: 400, h: 300, tall: false },
  { label: "barra", w: 400, h: 300, tall: false },
  { label: "picada tabla", w: 400, h: 300, tall: false },
  { label: "karaoke jueves", w: 400, h: 500, tall: true },
  { label: "parche afuera", w: 400, h: 300, tall: false },
];
---

<section id="gallery" class="py-14 px-5 border-t border-line md:py-20 md:px-8 lg:py-24 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="La vibra"
      title="COMO SE VE"
    />
  
    <div class="grid grid-cols-2 auto-rows-[120px] gap-2 mt-7 md:grid-cols-3 md:auto-rows-[160px] md:gap-3 lg:grid-cols-4 lg:auto-rows-[180px] lg:gap-4">
      {shots.map((shot) => (
        <div class={shot.tall ? "row-span-2" : ""}>
          <PlaceholderImg
            label={shot.label}
            w={shot.w}
            class="h-full"
          />
        </div>
      ))}
    </div>
  
    <!-- Social proof strip -->
    <div class="mt-6 flex justify-center items-center gap-3 py-3.5 px-4 border border-line rounded-xl sm:w-fit mx-auto md:mt-8 md:py-4 md:px-10 lg:mt-10">
      <div class="flex gap-0.5 text-accent">
        {[0, 1, 2, 3, 4].map(() => (
          <Icon name="star" size="sm" />
        ))}
      </div>
      <div>
        <div class="font-body text-sm font-semibold">4.7 / 5</div>
        <div class="font-mono text-xxs text-muted tracking-neon">
          +340 reseñas en Google
        </div>
      </div>
    </div>
  </div>
</section>
