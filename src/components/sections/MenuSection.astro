---
import SectionHeader from "../ui/SectionHeader.astro";
import { MENU, type MenuTab } from "../../data/content";

const tabs: { id: MenuTab; label: string }[] = [
  { id: "beers", label: "Cervezas" },
  { id: "shots", label: "Tragos" },
  // { id: "picar", label: "Para picar" },
];
---

<div id="menu" class="py-14 px-5 border-t border-line space-y-8 md:py-20 md:px-8 lg:py-24 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Carta destacada"
      title="QUÉ TOMAR"
      sub="Una selección. La carta completa está en el bar."
    />
  
    <div class="mt-8">
      <!-- Tab bar -->
      <div class="flex justify-center gap-1.5 p-1 mb-4 bg-bg-2 border border-line rounded-full mx-auto md:w-fit md:max-w-md" data-menu-tabs>
        {tabs.map((t) => (
          <button
            data-tab={t.id}
            class={`flex-1 py-2.5 px-2 rounded-full font-body text-xs font-semibold tracking-[0.04em] transition-all duration-150 md:text-sm md:py-3 md:px-18 ${
              t.id === "beers"
                ? "bg-accent text-bg"
                : "text-fg"
            }`}
          >
            {t.label}
          </button>
        ))}
      </div>
  
      <!-- Menu panels -->
      {(tabs).map((t) => (
        <div data-panel={t.id} class={t.id !== "beers" ? "hidden" : ""}>
          <div class="flex flex-col">
            {MENU[t.id].map((item) => (
              <div class="py-4 flex gap-3 items-start not-last:border-b not-last:border-line md:py-5 md:gap-4 lg:py-6">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <h3 class="font-display font-medium text-lg m-0 text-fg md:text-xl lg:text-2xl">
                      {item.name}
                    </h3>
                    {item.tag && (
                      <span class="font-mono text-xxs tracking-wide uppercase text-accent border border-accent py-px px-1.5 rounded-sm md:text-xs">
                        {item.tag}
                      </span>
                    )}
                  </div>
                  <div class="font-body text-xs text-muted mt-0.5 md:text-sm">
                    {item.desc}
                  </div>
                </div>
                <div class="font-display text-lg text-fg whitespace-nowrap md:text-xl lg:text-2xl">
                  {item.price}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Tab switching — vanilla JS island
  const tabContainer = document.querySelector("[data-menu-tabs]");

  if (tabContainer) {
    const buttons = tabContainer.querySelectorAll("[data-tab]");
    const panels = document.querySelectorAll("[data-panel]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tabId = btn.getAttribute("data-tab");

        // Update button styles
        buttons.forEach((b) => {
          b.classList.remove("bg-accent", "text-bg");
          b.classList.add("text-fg");
        });

        btn.classList.remove("text-fg");
        btn.classList.add("bg-accent", "text-bg");

        // Show/hide panels
        panels.forEach((panel) => {
          if (panel.getAttribute("data-panel") === tabId) {
            panel.classList.remove("hidden");
          } else {
            panel.classList.add("hidden");
          }
        });
      });
    });
  }
</script>
