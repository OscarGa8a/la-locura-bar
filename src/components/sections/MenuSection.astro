---
import SectionHeader from '../ui/SectionHeader.astro';
import { MENU, type MenuTab } from '../../data/content';
import { CldImage } from 'astro-cloudinary';

const tabs: { id: MenuTab; label: string }[] = [
  { id: 'beersPersonal', label: 'Cervezas personales' },
  { id: 'beersShare', label: 'Cervezas para compartir' },
  { id: 'liquors', label: 'Licores' },
];

function formatPrice(price: number): string {
  return '$' + price.toLocaleString('es-CO');
}
---

<div id="menu" class="py-14 px-5 border-t border-line md:py-20 md:px-8 lg:py-24 lg:px-12">
  <div class="max-w-7xl mx-auto space-y-8" data-animate-container>
    <SectionHeader
      eyebrow="Carta destacada"
      title="QUÉ TOMAR"
      sub="Una selección. La carta completa está en el bar."
      data-animate="fade-up"
    />

    <!-- Tabs (scrollable on mobile, centered on desktop) -->
    <div
      class="flex overflow-x-auto scrollbar-width:none [&::-webkit-scrollbar]:hidden scroll-smooth snap-x snap-mandatory gap-2 pb-1 md:justify-center md:gap-3 md:overflow-visible md:snap-none"
      data-menu-tabs
      data-animate="fade-up"
      data-animate-delay="2"
      role="tablist"
      aria-label="Categorías de la carta"
    >
      {tabs.map((t) => {
        const isActive = t.id === 'beersPersonal';
        return (
          <button
            id={`menu-tab-${t.id}`}
            type="button"
            data-tab={t.id}
            role="tab"
            aria-selected={isActive ? 'true' : 'false'}
            aria-controls={`menu-panel-${t.id}`}
            tabindex={isActive ? '0' : '-1'}
            class={`shrink-0 snap-start py-2.5 px-5 rounded-full font-body text-xs font-semibold tracking-[0.04em] transition-all duration-150 border md:text-sm md:py-3 md:px-6 ${
              isActive
                ? 'bg-accent text-bg border-accent'
                : 'bg-bg-2 text-fg border-line hover:border-line-strong'
            }`}
          >
            {t.label}
          </button>
        );
      })}
    </div>

    <!-- Menu panels -->
    {tabs.map((t) => {
      const items = MENU[t.id];
      const featured = items.filter((i) => i.featured);
      const list = items.filter((i) => !i.featured);
      return (
        <div
          id={`menu-panel-${t.id}`}
          data-panel={t.id}
          role="tabpanel"
          aria-labelledby={`menu-tab-${t.id}`}
          tabindex="0"
          hidden={t.id !== 'beersPersonal'}
          class={t.id !== 'beersPersonal' ? 'hidden' : ''}
        >
          {/* Featured cards */}
          {featured.length > 0 && (
            <div class="grid grid-cols-1 gap-4 mb-8 sm:grid-cols-2">
              {featured.map((item, index) => (
                <div class="group bg-bg-2 rounded-xl border border-line overflow-hidden transition-all duration-300 hover:border-accent hover:shadow-neon"
                  data-animate="scale-in"
                  data-animate-delay={String(Math.min(index + 1, 8))}
                >
                  {/* Image placeholder */}
                  <div class="h-100 lg:h-140 w-full bg-bg-3 border-b border-line flex items-center justify-center text-muted font-mono text-xs uppercase tracking-wide" aria-label={`Imagen de ${item.name}`} role="img">
                    <CldImage
                      src={item.image}
                      alt={item.name}
                      width={800}
                      height={800}
                      sizes="(min-width: 640px) 50vw, 100vw"
                      loading="lazy"
                      class="h-full w-full object-contain"
                    />
                  </div>
                  <div class="p-4 md:p-5">
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                      <h3 class="font-display font-medium text-lg text-fg md:text-xl lg:text-2xl">
                        {item.name}
                      </h3>
                      {item.tag && (
                        <span class="font-mono text-xxs tracking-wide uppercase text-accent border border-accent py-px px-1.5 rounded-sm md:text-xs">
                          {item.tag}
                        </span>
                      )}
                    </div>
                    <p class="font-body text-xs text-muted md:text-sm">
                      {item.desc}
                    </p>
                    <div class="font-display text-xl text-fg mt-2 md:text-2xl">
                      {formatPrice(item.price)}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* List with thumbnails */}
          <div class="flex flex-col">
            {list.map((item, index) => (
              <div class="py-4 flex gap-3 items-start not-last:border-b not-last:border-line md:py-5 md:gap-4 lg:py-6"
                data-animate="fade-up"
                data-animate-delay={String(Math.min(index + 1, 8))}
              >
                {/* Thumbnail */}
                <div class="shrink-0 w-16 h-16 rounded-lg border border-line flex items-center justify-center md:w-18 md:h-18" aria-label={`Imagen pendiente de ${item.name}`}>
                  <CldImage
                    src={item.image}
                    alt={item.name}
                    width={128}
                    height={128}
                    loading="lazy"
                    sizes="72px"
                    class="shrink-0 w-full h-full rounded-lg object-contain"
                  />
                </div>
                
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <h3 class="font-display font-medium text-lg m-0 text-fg md:text-xl lg:text-2xl">
                      {item.name}
                    </h3>
                    {item.tag && (
                      <span class="font-mono text-xxs tracking-wide uppercase text-accent border border-accent py-px px-1.5 rounded-sm md:text-xs">
                        {item.tag}
                      </span>
                    )}
                  </div>
                  <div class="font-body text-xs text-muted mt-0.5 md:text-sm">
                    {item.desc}
                  </div>
                </div>
                <div class="font-display text-lg text-fg whitespace-nowrap md:text-xl lg:text-2xl">
                  {formatPrice(item.price)}
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</div>

<script>
  const tabContainer = document.querySelector('[data-menu-tabs]') as HTMLElement | null;
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  function setActiveStyles(button: HTMLElement, isActive: boolean) {
    button.classList.toggle('bg-accent', isActive);
    button.classList.toggle('text-bg', isActive);
    button.classList.toggle('border-accent', isActive);
    button.classList.toggle('text-fg', !isActive);
    button.classList.toggle('bg-bg-2', !isActive);
    button.classList.toggle('border-line', !isActive);
    button.setAttribute('aria-selected', String(isActive));
    button.setAttribute('tabindex', isActive ? '0' : '-1');
  }

  function switchTab(tabId: string | null, focusTab = false) {
    if (!tabId || !tabContainer) return;

    const buttons = Array.from(tabContainer.querySelectorAll<HTMLButtonElement>('[data-tab]'));

    buttons.forEach((button) => {
      setActiveStyles(button, button.dataset.tab === tabId);
    });

    const activeBtn = buttons.find((button) => button.dataset.tab === tabId);
    if (focusTab) {
      activeBtn?.focus();
    }

    panels.forEach((panel) => {
      const isActive = panel.dataset.panel === tabId;
      panel.hidden = !isActive;
      panel.classList.toggle('hidden', !isActive);
    });

    if (activeBtn && window.innerWidth < 768) {
      tabContainer.scrollTo({
        left: activeBtn.offsetLeft - tabContainer.offsetLeft,
        behavior: prefersReducedMotion.matches ? 'auto' : 'smooth',
      });
    }
  }

  if (tabContainer) {
    const buttons = Array.from(tabContainer.querySelectorAll<HTMLButtonElement>('[data-tab]'));

    buttons.forEach((btn, index) => {
      btn.addEventListener('click', () => {
        switchTab(btn.dataset.tab ?? null);
      });

      btn.addEventListener('keydown', (event) => {
        const lastIndex = buttons.length - 1;
        let nextIndex = index;

        if (event.key === 'ArrowRight') {
          nextIndex = index === lastIndex ? 0 : index + 1;
        } else if (event.key === 'ArrowLeft') {
          nextIndex = index === 0 ? lastIndex : index - 1;
        } else if (event.key === 'Home') {
          nextIndex = 0;
        } else if (event.key === 'End') {
          nextIndex = lastIndex;
        } else {
          return;
        }

        event.preventDefault();
        switchTab(buttons[nextIndex]?.dataset.tab ?? null, true);
      });
    });
  }
</script>
