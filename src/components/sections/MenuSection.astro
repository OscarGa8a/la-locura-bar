---
import SectionHeader from "../ui/SectionHeader.astro";
import { MENU, type MenuTab } from "../../data/content";

const tabs: { id: MenuTab; label: string }[] = [
  { id: "beersPersonal", label: "Cervezas personales" },
  { id: "beersShare", label: "Cervezas para compartir" },
  { id: "licores", label: "Licores" },
];
---

<div id="menu" class="py-14 px-5 border-t border-line space-y-8 md:py-20 md:px-8 lg:py-24 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Carta destacada"
      title="QUÉ TOMAR"
      sub="Una selección. La carta completa está en el bar."
    />

    <div class="mt-8">
      <!-- Tabs (scrollable on mobile, centered on desktop) -->
      <div
        class="flex overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden scroll-smooth snap-x snap-mandatory gap-2 pb-1 mb-6 md:justify-center md:gap-3 md:overflow-visible md:snap-none"
        data-menu-tabs
      >
        {tabs.map((t) => (
          <button
            data-tab={t.id}
            class={`shrink-0 snap-start py-2.5 px-5 rounded-full font-body text-xs font-semibold tracking-[0.04em] transition-all duration-150 border md:text-sm md:py-3 md:px-6 ${
              t.id === "beersPersonal"
                ? "bg-accent text-bg border-accent"
                : "bg-bg-2 text-fg border-line hover:border-line-strong"
            }`}
          >
            {t.label}
          </button>
        ))}
      </div>

      <!-- Menu panels -->
      {tabs.map((t) => {
        const items = MENU[t.id];
        const featured = items.filter((i) => i.featured);
        const list = items.filter((i) => !i.featured);
        return (
          <div
            data-panel={t.id}
            class={t.id !== "beersPersonal" ? "hidden" : ""}
          >
            {/* Featured cards */}
            {featured.length > 0 && (
              <div class="grid grid-cols-1 gap-4 mb-8 sm:grid-cols-2">
                {featured.map((item) => (
                  <div class="group bg-bg-2 rounded-xl border border-line overflow-hidden transition-all duration-300 hover:border-accent hover:shadow-neon">
                    {/* Image placeholder */}
                    <div class="aspect-16/10 w-full bg-bg-3 border-b border-line flex items-center justify-center text-muted font-mono text-xs uppercase tracking-wide">
                      <span class="flex items-center gap-1.5">
                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-muted animate-pulse" />
                        {item.image}
                      </span>
                    </div>
                    <div class="p-4 md:p-5">
                      <div class="flex items-center gap-2 flex-wrap mb-1">
                        <h3 class="font-display font-medium text-lg text-fg md:text-xl lg:text-2xl">
                          {item.name}
                        </h3>
                        {item.tag && (
                          <span class="font-mono text-xxs tracking-wide uppercase text-accent border border-accent py-px px-1.5 rounded-sm md:text-xs">
                            {item.tag}
                          </span>
                        )}
                      </div>
                      <p class="font-body text-xs text-muted md:text-sm">
                        {item.desc}
                      </p>
                      <div class="font-display text-xl text-fg mt-2 md:text-2xl">
                        {item.price}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}

            {/* List with thumbnails */}
            <div class="flex flex-col">
              {list.map((item) => (
                <div class="py-4 flex gap-3 items-start not-last:border-b not-last:border-line md:py-5 md:gap-4 lg:py-6">
                  {/* Thumbnail */}
                  <div class="shrink-0 w-16 h-16 rounded-lg bg-bg-3 border border-line flex items-center justify-center text-muted font-mono text-xxs uppercase tracking-wide md:w-18 md:h-18">
                    {item.image}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <h3 class="font-display font-medium text-lg m-0 text-fg md:text-xl lg:text-2xl">
                        {item.name}
                      </h3>
                      {item.tag && (
                        <span class="font-mono text-xxs tracking-wide uppercase text-accent border border-accent py-px px-1.5 rounded-sm md:text-xs">
                          {item.tag}
                        </span>
                      )}
                    </div>
                    <div class="font-body text-xs text-muted mt-0.5 md:text-sm">
                      {item.desc}
                    </div>
                  </div>
                  <div class="font-display text-lg text-fg whitespace-nowrap md:text-xl lg:text-2xl">
                    {item.price}
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</div>

<script>
  const tabContainer = document.querySelector("[data-menu-tabs]");
  const panels = document.querySelectorAll("[data-panel]");

  function switchTab(tabId: string | null) {
    if (!tabId) return;

    if (tabContainer) {
      const buttons = tabContainer.querySelectorAll("[data-tab]");
      buttons.forEach((b) => {
        b.classList.remove("bg-accent", "text-bg", "border-accent");
        b.classList.add("text-fg", "bg-bg-2", "border-line");
      });

      const activeBtn = tabContainer.querySelector(`[data-tab="${tabId}"]`);
      if (activeBtn) {
        activeBtn.classList.remove("text-fg", "bg-bg-2", "border-line");
        activeBtn.classList.add("bg-accent", "text-bg", "border-accent");
      }
    }

    panels.forEach((panel) => {
      if (panel.getAttribute("data-panel") === tabId) {
        panel.classList.remove("hidden");
      } else {
        panel.classList.add("hidden");
      }
    });
  }

  if (tabContainer) {
    const buttons = tabContainer.querySelectorAll("[data-tab]");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tabId = btn.getAttribute("data-tab");
        switchTab(tabId);

        if (window.innerWidth < 768) {
          tabContainer.scrollTo({
            left: btn.offsetLeft - tabContainer.offsetLeft,
            behavior: "smooth",
          });
        }
      });
    });
  }
</script>
