---
import SectionHeader from "../ui/SectionHeader.astro";
import { config } from "../../data/config";
import Icon from "../ui/Icons.astro";
import Button from "../ui/Button.astro";

const { address, neighborhood, location, whatsappNumber, whatsapp } = config;

const coordinates = `${location.lat},${location.lng}`;
const mapEmbedUrl = `https://www.google.com/maps?q=${coordinates}&z=15&output=embed`;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${coordinates}`;
---

<section id="location" class="py-14 px-5">
  <SectionHeader
    eyebrow="Dónde estamos"
    title="UBICACIÓN"
  />

  <!-- Stylized map -->
  <div class="mt-6 aspect-4/3 relative overflow-hidden rounded-lg border border-line">
    <iframe
      title="Ubicación de La Locura Bar en Villavicencio"
      src={mapEmbedUrl}
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      aria-describedby="service-map-help"
    ></iframe>
  </div>

  <!-- Info rows -->
  <div class="mt-6 flex flex-col gap-3.5">
    <div class="flex gap-3.5 items-start">
      <div class="w-9 h-9 flex items-center justify-center border border-line-strong rounded-full text-accent shrink-0">
        <Icon name="pin" />
      </div>
      <div>
        <div class="font-body text-sm font-semibold">{address}</div>
        <div class="font-body text-xs text-muted mt-0.5">{neighborhood}</div>
      </div>
    </div>

    <div class="flex gap-3.5 items-start">
      <div class="w-9 h-9 flex items-center justify-center border border-line-strong rounded-full text-accent shrink-0">
        <Icon name="clock" />
      </div>
      <div>
        <div class="font-body text-sm font-semibold">{config.horario1Text}</div>
        <div class="font-body text-sm font-semibold">{config.horario2Text}</div>
        <div class="font-body text-xs text-muted mt-0.5">{config.horatio3Text}</div>
      </div>
    </div>

      <a href={`https://wa.me/${whatsapp}`} target="_blank" rel="noopener noreferrer" class="flex gap-3.5 items-start">
        <div class="w-9 h-9 flex items-center justify-center border border-line-strong rounded-full text-accent shrink-0">
          <Icon name="phone" />
        </div>
        <div>
          <div class="font-body text-sm font-semibold">{whatsappNumber}</div>
          <div class="font-body text-xs text-muted mt-0.5">WhatsApp para reservas</div>
        </div>
      </a>
  </div>

  <!-- Cómo llegar button -->
  <Button variant="outline" href={directionsUrl} target="_blank" class="mt-5 w-full flex justify-center items-center    rounded-2xl gap-2">
    Cómo llegar <Icon name="arrow" />
  </Button>
</section>
