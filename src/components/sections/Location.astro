---
import SectionHeader from "../ui/SectionHeader.astro";
import Icon from "../ui/Icons.astro";

interface InfoRow {
  icon: "pin" | "clock" | "phone";
  title: string;
  sub: string;
}

const infoRows: InfoRow[] = [
  { icon: "pin", title: "Carrera 43 #10-24", sub: "Barrio Poblado, Medellín · Colombia" },
  { icon: "clock", title: "Mar – Dom · 6:00 PM – 3:00 AM", sub: "Domingos cerramos a las 8 PM · Lunes cerrado" },
  { icon: "phone", title: "+57 300 123 4567", sub: "WhatsApp para reservas" },
];
---

<section id="location" class="py-14 px-5">
  <SectionHeader
    eyebrow="Dónde estamos"
    title="UBICACIÓN"
  />

  <!-- Stylized map -->
  <div class="mt-6 aspect-[4/3] relative overflow-hidden rounded-[14px] border border-line">
    <svg viewBox="0 0 400 300" class="w-full h-full bg-bg-3">
      <!-- Major streets -->
      <g stroke="var(--color-line-strong)" stroke-width="1" fill="none">
        <path d="M0 80 L400 120" />
        <path d="M0 160 L400 200" />
        <path d="M0 240 L400 280" />
        <path d="M80 0 L120 300" />
        <path d="M220 0 L260 300" />
        <path d="M340 0 L380 300" />
      </g>
      <!-- Minor streets -->
      <g stroke="var(--color-line)" stroke-width="0.5" fill="none">
        <path d="M0 40 L400 60" />
        <path d="M0 120 L400 160" />
        <path d="M0 200 L400 240" />
        <path d="M40 0 L70 300" />
        <path d="M160 0 L200 300" />
        <path d="M280 0 L320 300" />
      </g>
      <!-- Pin -->
      <circle cx="210" cy="155" r="28" fill="var(--color-accent)" opacity="0.15" />
      <circle cx="210" cy="155" r="16" fill="var(--color-accent)" opacity="0.3" />
      <circle cx="210" cy="155" r="6" fill="var(--color-accent)" />
      <text
        x="210"
        y="135"
        font-family="JetBrains Mono, monospace"
        font-size="9"
        fill="var(--color-fg)"
        text-anchor="middle"
        letter-spacing="1.5"
      >
        LA LOCURA
      </text>
    </svg>
  </div>

  <!-- Info rows -->
  <div class="mt-6 flex flex-col gap-3.5">
    {infoRows.map((row) => (
      <div class="flex gap-3.5 items-start">
        <div class="w-9 h-9 flex items-center justify-center border border-line-strong rounded-full text-accent shrink-0">
          <Icon name={row.icon} />
        </div>
        <div>
          <div class="font-body text-[15px] font-semibold">{row.title}</div>
          <div class="font-body text-[13px] text-muted mt-0.5">{row.sub}</div>
        </div>
      </div>
    ))}
  </div>

  <!-- Cómo llegar button -->
  <a
    href="#"
    class="mt-5 flex justify-center items-center gap-2 py-3.5 bg-bg-3 border border-line-strong rounded-full font-body text-[13px] font-semibold"
  >
    Cómo llegar <Icon name="arrow" />
  </a>
</section>
