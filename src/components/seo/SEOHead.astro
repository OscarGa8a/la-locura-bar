---
import { config } from '../../data/config';
import { socialNetworks } from '../../data/social-networks';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalURL?: string;
  noIndex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogImage = config.defaultOgImage,
  ogImageAlt = config.defaultOgImageAlt,
  canonicalURL,
  noIndex = false,
  jsonLd,
} = Astro.props;

const fullTitle = `${title} | ${config.siteName}`;
const siteUrl = config.siteUrl;

const toAbsoluteUrl = (value?: string) => {
  if (!value) return undefined;
  try {
    return new URL(value).href;
  } catch {
    return siteUrl ? new URL(value, siteUrl).href : undefined;
  }
};

const canonicalHref = toAbsoluteUrl(canonicalURL ?? Astro.url.pathname);
const absoluteOgImage = toAbsoluteUrl(ogImage);
const sitemapUrl = siteUrl ? new URL('/sitemap-index.xml', siteUrl).href : undefined;
const homeUrl = siteUrl ? new URL('/', siteUrl).href : undefined;
const menuUrl = siteUrl ? new URL('/#menu', siteUrl).href : undefined;
const reserveUrl = siteUrl ? new URL('/#reserve', siteUrl).href : undefined;
const locationUrl = siteUrl ? new URL('/#location', siteUrl).href : undefined;
const llmsUrl = siteUrl ? new URL('/llms.txt', siteUrl).href : undefined;
const businessId = siteUrl ? `${siteUrl}/#business` : undefined;
const organizationId = siteUrl ? `${siteUrl}/#organization` : undefined;
const websiteId = siteUrl ? `${siteUrl}/#website` : undefined;
const sameAs = [...socialNetworks.map((social) => social.href), config.googleMapsUrl];
const mapsUrl = config.googleMapsUrl;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  ...(organizationId ? { '@id': organizationId } : {}),
  name: config.siteName,
  legalName: config.legalName,
  ...(homeUrl ? { url: homeUrl } : {}),
  ...(absoluteOgImage ? { logo: absoluteOgImage, image: absoluteOgImage } : {}),
  sameAs,
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: config.whatsappNumber,
    contactType: 'reservations',
    areaServed: config.addressCountryCode,
    availableLanguage: ['Spanish'],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  ...(websiteId ? { '@id': websiteId } : {}),
  name: config.siteName,
  description: config.seoDescription,
  inLanguage: 'es-CO',
  ...(homeUrl ? { url: homeUrl } : {}),
  ...(businessId ? { about: { '@id': businessId } } : {}),
  ...(organizationId ? { publisher: { '@id': organizationId } } : {}),
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': config.schemaType,
  name: config.siteName,
  legalName: config.legalName,
  description: config.seoDescription,
  ...(businessId ? { '@id': businessId } : {}),
  ...(homeUrl ? { url: homeUrl } : {}),
  ...(absoluteOgImage ? { image: absoluteOgImage, logo: absoluteOgImage } : {}),
  ...(organizationId ? { parentOrganization: { '@id': organizationId } } : {}),
  telephone: config.whatsappNumber,
  priceRange: config.priceRange,
  currenciesAccepted: config.currenciesAccepted,
  acceptsReservations: true,
  publicAccess: true,
  areaServed: config.areaServed,
  knowsAbout: config.primaryServices,
  ...(menuUrl ? { hasMenu: menuUrl } : {}),
  ...(mapsUrl ? { hasMap: mapsUrl } : {}),
  address: {
    '@type': 'PostalAddress',
    streetAddress: config.address,
    addressLocality: config.addressLocality,
    addressRegion: config.addressRegion,
    addressCountry: config.addressCountryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: config.location.lat,
    longitude: config.location.lng,
  },
  openingHours: config.openingHours,
  openingHoursSpecification: config.openingHoursSpecification,
  sameAs,
  potentialAction: [
    {
      '@type': 'ReserveAction',
      name: 'Reservar mesa por WhatsApp',
      target: config.whatsappReserveUrl,
      ...(reserveUrl ? { url: reserveUrl } : {}),
    },
    ...(locationUrl
      ? [
          {
            '@type': 'ViewAction',
            name: 'Ver ubicación de La Locura Bar en Google Maps',
            target: mapsUrl,
            url: locationUrl,
          },
        ]
      : []),
  ],
  ...(llmsUrl ? { subjectOf: { '@type': 'DigitalDocument', name: 'AI-readable site summary', url: llmsUrl } } : {}),
};

const structuredData = [
  organizationSchema,
  websiteSchema,
  localBusinessSchema,
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta
  name="robots"
  content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'}
/>
<meta name="theme-color" content={config.themeColor} />
{canonicalHref && <link rel="canonical" href={canonicalHref} />}
{sitemapUrl && <link rel="sitemap" href={sitemapUrl} />}

<!-- Open Graph -->
<meta property="og:type" content="website" />
{canonicalHref && <meta property="og:url" content={canonicalHref} />}
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
{absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}
{absoluteOgImage && <meta property="og:image:width" content="1200" />}
{absoluteOgImage && <meta property="og:image:height" content="630" />}
{absoluteOgImage && <meta property="og:image:alt" content={ogImageAlt} />}
<meta property="og:locale" content={config.locale} />
<meta property="og:site_name" content={config.siteName} />

<!-- Twitter / X Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}
{absoluteOgImage && <meta name="twitter:image:alt" content={ogImageAlt} />}

<!-- Structured data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>

<!-- Favicons -->
<link rel="icon" type="image/x-icon" href="/favicon.png" />
<link rel="icon" type="image/png" sizes="96x96" href="/images/favicon-96x96.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
