---
interface Props {
  variant?: 'primary' | 'outline' | 'secondary' | 'outline-secondary';
  href?: string;
  type?: 'submit' | 'link';
  class?: string;
  target?: string;
  rel?: string;
}

const { variant = 'primary', href, type = 'link', class: className = '', target, rel } = Astro.props;

const base = 'py-3.5 px-5 font-display text-base tracking-wide uppercase inline-flex items-center gap-2 shadow-xl md:py-4 md:px-6 md:text-sm';

const variants = {
  primary: 'bg-accent text-bg hover:bg-accent/80',
  outline: 'border border-accent text-accent hover:bg-accent/10',
  secondary: 'bg-accent-2 text-bg hover:bg-accent-2/80',
  'outline-secondary': 'border border-accent-2 text-accent-2 hover:bg-accent-2/10',
};
---

{
  type === 'link' ? (
    <a href={href} target={target} rel={rel} class={`${base} ${variants[variant]} ${className}`}>
      <slot />
    </a>
  ): (
    <button type="submit" class={`${base} ${variants[variant]} ${className}`}>
      <slot />
    </button>
  )
}
