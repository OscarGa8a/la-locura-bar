---
interface Props {
  name: string;
  class?: string;
  size?: "xs" | "sm" | "md" | "lg" | "xl" | "2xl";
}

const { name, class: className = "", size = "md", } = Astro.props;

const sizes = {
  xs: "w-3 h-3",
  sm: "w-4 h-4",
  md: "w-5 h-5",
  lg: "w-6 h-6",
  xl: "w-8 h-8",
  '2xl': "w-10 h-10",
};
---

{
  name === "menu" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <path d="M3 6h18M3 12h18M3 18h18" />
    </svg>
  )
}
{
  name === "close" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <path d="M6 6l12 12M18 6L6 18" />
    </svg>
  )
}
{
  name === "pin" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <path d="M12 22s-7-7.58-7-13a7 7 0 0 1 14 0c0 5.42-7 13-7 13z" />
      <circle cx="12" cy="9" r="2.5" />
    </svg>
  )
}
{
  name === "clock" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 2" />
    </svg>
  )
}
{
  name === "phone" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
    </svg>
  )
}
{
  name === "instagram" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <rect x="3" y="3" width="18" height="18" rx="5" />
      <circle cx="12" cy="12" r="4" />
      <circle cx="17.5" cy="6.5" r=".8" fill="currentColor" />
    </svg>
  )
}
{
  name === "tiktok" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <path d="M14 4v9.5a3.5 3.5 0 1 1-3.5-3.5" />
      <path d="M14 4c.5 2.5 2 4 4.5 4.5" />
    </svg>
  )
}
{
  name === "facebook" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
    </svg>
  )
}
{
  name === "whatsapp" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <path d="M21 12a9 9 0 1 1-16.5-5L3 21l4.2-1.5A9 9 0 0 0 21 12z" />
      <path d="M8.5 9.5c0 3 3 6 6 6l1.5-1.5-2-1-1 1c-1 0-2.5-1.5-2.5-2.5l1-1-1-2z" />
    </svg>
  )
}
{
  name === "arrow" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  )
}
{
  name === "star" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l3 7 7 .5-5.5 4.5 2 7-6.5-4-6.5 4 2-7L2 9.5 9 9z" />
    </svg>
  )
}
{
  name === "sparkle" && (
    <svg class={`${className} ${sizes[size]}`} viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l1.5 6 6 1.5-6 1.5L12 17l-1.5-6-6-1.5 6-1.5z" />
    </svg>
  )
}
